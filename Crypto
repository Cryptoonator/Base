<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CryptoMentor - Twoja strona o kryptowalutach</title>
  <style>
    body { margin:0; font-family: Arial, sans-serif; background:#f5f7fa; color:#1c1c1c; }
    header { background: linear-gradient(90deg, #1a2a6c, #b21f1f, #fdbb2d); color:white; padding:2rem; text-align:center; }
    nav a { color:white; margin:0 1rem; text-decoration:none; font-weight:bold; }
    section { padding:2rem; max-width:1000px; margin:auto; }
    h2 { color:#1a2a6c; }
    .crypto-ranking { display:flex; flex-wrap:wrap; gap:1rem; }
    .crypto-card { background:white; padding:1rem; border-radius:10px; box-shadow:0 2px 5px rgba(0,0,0,0.1); flex:1 1 150px; text-align:center; }
    .blog-post { background:white; margin-bottom:1rem; padding:1rem; border-radius:10px; box-shadow:0 2px 5px rgba(0,0,0,0.1); }
    footer { background:#1c1c1c; color:white; text-align:center; padding:1rem; }
    input, button { padding:0.5rem; margin-top:0.5rem; border-radius:5px; border:1px solid #ccc; }
    button { background:#1a2a6c; color:white; border:none; cursor:pointer; }
  </style>
</head>
<body>

<header>
  <h1>CryptoMentor</h1>
  <p>Zacznij swoją przygodę z kryptowalutami!</p>
  <nav>
    <a href="#education">Edukacja</a>
    <a href="#ranking">Ranking</a>
    <a href="#blog">Blog</a>
    <a href="#newsletter">Newsletter</a>
  </nav>
</header>

<section id="education">
  <h2>Edukacja</h2>
  <p>Dowiedz się, czym są kryptowaluty, jak je kupować, przechowywać i inwestować bezpiecznie.</p>
  <ul>
    <li>Bitcoin, Ethereum i inne kryptowaluty</li>
    <li>Jak korzystać z portfela kryptowalutowego</li>
    <li>Bezpieczeństwo w świecie krypto</li>
    <li>Poradniki dla początkujących</li>
  </ul>
</section>

<section id="ranking">
  <h2>Ranking Kryptowalut</h2>
  <div class="crypto-ranking" id="cryptoContainer">
    <!-- Tutaj zostaną wstawione dane o kryptowalutach -->
  </div>
</section>

<section id="blog">
  <h2>Blog / Aktualności</h2>
  <div class="blog-post">
    <h3>Co to jest Bitcoin?</h3>
    <p>Bitcoin to pierwsza kryptowaluta, stworzona w 2009 roku. Pozwala na decentralizowane przechowywanie wartości i przesyłanie pieniędzy bez pośredników.</p>
  </div>
  <div class="blog-post">
    <h3>Trend NFT w 2026</h3>
    <p>NFT zyskują popularność w sztuce cyfrowej i grach. Dowiedz się, jak bezpiecznie w nie inwestować.</p>
  </div>
</section>

<section id="newsletter">
  <h2>Zapisz się do newslettera</h2>
  <p>Otrzymuj cotygodniowe analizy i alerty cenowe.</p>
  <form onsubmit="alert('Dziękujemy za zapis!'); return false;">
    <input type="email" placeholder="Twój email" required>
    <br>
    <button type="submit">Zapisz się</button>
  </form>
</section>

<footer>
  <p>© 2026 CryptoMentor. Wszystkie prawa zastrzeżone.</p>
</footer>

<script>
  // Przykładowe dane kryptowalut
  const cryptos = [
    {name:'Bitcoin', symbol:'BTC', price:'$27,300', change:'+2%'},
    {name:'Ethereum', symbol:'ETH', price:'$1,850', change:'-1.2%'},
    {name:'Cardano', symbol:'ADA', price:'$0.45', change:'+0.8%'},
    {name:'Solana', symbol:'SOL', price:'$22', change:'+1.5%'},
    {name:'Ripple', symbol:'XRP', price:'$0.52', change:'-0.5%'}
  ];

  const container = document.getElementById('cryptoContainer');
  cryptos.forEach(c => {
    const div = document.createElement('div');
    div.className = 'crypto-card';
    div.innerHTML = `<h3>${c.name} (${c.symbol})</h3><p>Cena: ${c.price}</p><p>Zmiana: ${c.change}</p>`;
    container.appendChild(div);
  });
</script>

</body>
</html>
